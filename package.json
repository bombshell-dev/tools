{
    "name": "@bomb.sh/tools",
    "version": "0.1.0",
    "type": "module",
    "license": "MIT",
    "bin": {
        "bsh": "dist/bin.js"
    },
    "description": "The internal dev, build, and lint CLI for Bombshell projects",
    "keywords": [
        "cli",
        "bombshell",
        "internal"
    ],
    "homepage": "https://bomb.sh",
    "author": {
        "name": "Bombshell",
        "email": "oss@bomb.sh",
        "url": "https://bomb.sh"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/bombshell-dev/tools.git"
    },
    "publishConfig": {
        "access": "public"
    },
    "exports": {
        "./*": "./dist/*",
        "./package.json": "./package.json",
        "./tsconfig.json": "./tsconfig.json"
    },
    "scripts": {
        "bsh": "clink exec",
        "dev": "pnpm run bsh dev",
        "build": "clink build",
        "format": "pnpm run bsh format",
        "init": "pnpm run bsh init",
        "lint": "pnpm run bsh lint",
        "test": "pnpm run bsh test"
    },
    "devDependencies": {
        "@changesets/cli": "^2.28.1",
        "@types/node": "^22.13.14",
        "clink": "link:../clink/packages/clink"
    },
    "dependencies": {
        "oxfmt": "^0.36.0",
        "oxlint": "^1.51.0",
        "publint": "^0.3.18",
        "tsdown": "^0.21.0-beta.2",
        "vitest": "^4.0.18"
    },
    "packageManager": "pnpm@10.4.0",
    "volta": {
        "node": "22.14.0"
    },
    "pnpm": {}
}
