{
  "$schema": "./node_modules/knip/schema-jsonc.json",
  "entry": [
    "src/index.ts",
    "src/test-utils/*.ts"
  ],
  "ignore": [
    "rules/**"
  ],
  "ignoreDependencies": [
    "@bomb.sh/args",
    "@tanstack/intent",
    "@typescript/native-preview",
    "oxfmt",
    "oxlint",
    "publint",
    "tsdown",
    "vitest"
  ]
}
